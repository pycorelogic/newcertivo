# ============================================================================
# CERTIVO BLOG - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update with your actual values

# ─── Flask Configuration ────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ─── Security ───────────────────────────────────────────────────────────────
# IMPORTANT: Generate a secure random key for production!
# You can generate one using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite (default for development)
DATABASE_URL=sqlite:///database.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/certivo_db

# MySQL
# DATABASE_URL=mysql://username:password@localhost:3306/certivo_db

# ─── Email Configuration ────────────────────────────────────────────────────
# Gmail SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=tahmeedahmad234@gmail.com
MAIL_PASSWORD=Qwerty123@*
MAIL_DEFAULT_SENDER=noreply@certivo.com
ADMIN_EMAIL=admin@certivo.com

# SendGrid
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key

# Mailgun
# MAIL_SERVER=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=postmaster@your-domain.mailgun.org
# MAIL_PASSWORD=your-mailgun-smtp-password

# ─── Site Information ───────────────────────────────────────────────────────
SITE_NAME=Certivo
SITE_TAGLINE=Insights, Ideas & Innovation
SITE_URL=http://localhost:5000
SITE_DESCRIPTION=A modern blog covering technology, business, lifestyle and travel.
SITE_AUTHOR=Certivo Team
SITE_TWITTER=@certivo
SITE_LOGO=

# ─── Google AdSense ─────────────────────────────────────────────────────────
ADSENSE_ENABLED=false
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ─── Google Analytics ───────────────────────────────────────────────────────
GA_TRACKING_ID=

# ─── File Upload Settings ───────────────────────────────────────────────────
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,svg

# ─── Pagination ─────────────────────────────────────────────────────────────
POSTS_PER_PAGE=9
COMMENTS_PER_PAGE=20
ADMIN_ITEMS_PER_PAGE=20

# ─── Production Settings ────────────────────────────────────────────────────
# Uncomment these for production deployment

# FLASK_ENV=production
# FLASK_DEBUG=0
# SESSION_COOKIE_SECURE=true
# REMEMBER_COOKIE_SECURE=true
# WTF_CSRF_ENABLED=true

# ─── Third Party Services ───────────────────────────────────────────────────
# Cloudflare Turnstile (CAPTCHA alternative)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Cloudinary (Image hosting)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# AWS S3 (File storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=

# ─── Social Media Links ─────────────────────────────────────────────────────
SOCIAL_TWITTER=https://twitter.com/certivo
SOCIAL_FACEBOOK=https://facebook.com/certivo
SOCIAL_INSTAGRAM=https://instagram.com/certivo
SOCIAL_LINKEDIN=https://linkedin.com/company/certivo
SOCIAL_GITHUB=https://github.com/certivo

# ─── Advanced Settings ──────────────────────────────────────────────────────
# Session lifetime in days
SESSION_LIFETIME_DAYS=7
REMEMBER_COOKIE_DURATION_DAYS=14

# CSRF token time limit in seconds
WTF_CSRF_TIME_LIMIT=3600

# Database connection pool settings
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=3600

# ─── Development Tools ──────────────────────────────────────────────────────
# Flask-DebugToolbar
# FLASK_DEBUG_TOOLBAR_ENABLED=true

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
LOG_FILE=logs/certivo.log

# ─── Notes ──────────────────────────────────────────────────────────────────
# - Never commit the actual .env file to version control
# - Use strong, unique passwords and API keys
# - For Gmail, use App Passwords if 2FA is enabled
# - Update SITE_URL to your actual domain in production
# - Generate a new SECRET_KEY for production
# - Enable HTTPS in production (SESSION_COOKIE_SECURE=true)
